# Groq API key (required for AI processing) — get one free at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Optional: Gmail OAuth — saves drafts in Gmail browser WITH attachments
# Create at https://console.cloud.google.com/apis/credentials (Web application)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8501

# SMTP settings for sending complaint emails (optional — preview mode works without these)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
SMTP_FROM=your_email@gmail.com
